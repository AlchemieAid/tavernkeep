# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role Key (server-only, NEVER expose to the browser)
# Required by the admin data browser, audit log writes, and the
# schema discovery RPC. The application enforces admin authorization
# in lib/admin/auth.ts before this key is ever used to touch data.
# Find it in Supabase Dashboard -> Project Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI Provider Configuration
# Choose which AI provider to use: openai, gemini, or claude
# Defaults to 'gemini' for speed (2-8 seconds vs 60-90 seconds for OpenAI)
AI_PROVIDER=gemini

# OpenAI Configuration (if using AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Google Gemini Configuration (if using AI_PROVIDER=gemini) - RECOMMENDED
# Get your API key from: https://aistudio.google.com/app/apikey
# Available models: gemini-2.5-flash-lite (current), gemini-1.5-pro, gemini-1.5-flash
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

# Claude Configuration (if using AI_PROVIDER=claude) - NOT YET IMPLEMENTED
# CLAUDE_API_KEY=your_claude_api_key
# CLAUDE_MODEL=claude-3-haiku-20240307

# Application URL
# For local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# After deployment, update to your Vercel URL:
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ============================================================================
# GOOGLE OAUTH SETUP (DEFERRED UNTIL DEPLOYMENT)
# ============================================================================
# 
# Google OAuth requires a deployed URL for the redirect callback.
# Follow these steps AFTER deploying to Vercel:
#
# 1. Deploy this app to Vercel and note your deployment URL
#
# 2. Go to Google Cloud Console (console.cloud.google.com)
#    - Create a new project or select an existing one
#    - Enable the Google+ API
#    - Go to "Credentials" → "Create Credentials" → "OAuth 2.0 Client ID"
#    - Application type: Web application
#    - Authorized redirect URIs: https://[your-project].supabase.co/auth/v1/callback
#    - Copy the Client ID and Client Secret
#
# 3. Go to Supabase Dashboard → Authentication → Providers → Google
#    - Enable the Google provider
#    - Paste your Google Client ID
#    - Paste your Google Client Secret
#    - Save
#
# 4. Update NEXT_PUBLIC_APP_URL above to your Vercel deployment URL
#
# 5. Test the login flow at https://your-app.vercel.app/login
#
# ============================================================================
