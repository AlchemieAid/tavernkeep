    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.47",
    "supabase": "^2.87.2",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
