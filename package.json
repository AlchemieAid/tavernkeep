{
  "name": "tavernkeep",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:security": "jest __tests__/security",
    "test:rls-audit": "jest __tests__/security/rls-policy-audit.test.ts",
    "test:architecture": "jest __tests__/architecture",
    "test:admin": "jest __tests__/admin",
    "test:admin:security": "jest __tests__/admin/security.test.ts",
    "test:admin:integration": "jest __tests__/admin/integration.test.ts",
    "validate": "npm run lint && npm run type-check && npm test",
    "validate:quick": "npm run lint && npm run type-check",
    "prepare": "husky || true",
    "test:world": "vitest run --config vitest.config.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "dependencies": {
