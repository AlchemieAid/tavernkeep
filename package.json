    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.460.0",
    "nanoid": "^5.0.0",
    "next": "^14.2.0",
    "openai": "^4.67.0",
    "qrcode.react": "^4.2.0",
    "rbush": "^4.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
